TELEGRAM_TOKEN=your-telegram-bot-token
MONGO_URI=mongodb://localhost:27017
MONGO_DB=sleepjirabot
LOG_LEVEL=debug

# Jira Cloud OAuth 2.0 (create app at https://developer.atlassian.com/console/myapps/)
JIRA_CLIENT_ID=your-jira-client-id
JIRA_CLIENT_SECRET=your-jira-client-secret
JIRA_REDIRECT_URI=https://apenkin.pro/jira-bot/callback
JIRA_WEBHOOK_SECRET=your-jira-webhook-secret
POLL_INTERVAL=30s
BATCH_WINDOW=1m
CALLBACK_ADDR=:8080

# 32-byte key for AES-256-GCM token encryption (64 hex characters)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-64-char-hex-encryption-key

# Admin panel (optional) — your Telegram user ID
# ADMIN_TELEGRAM_ID=123456789

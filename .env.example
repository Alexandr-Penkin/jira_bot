TELEGRAM_TOKEN=your-telegram-bot-token
MONGO_URI=mongodb://localhost:27017
MONGO_DB=sleepjirabot
LOG_LEVEL=debug

# Jira Cloud OAuth 2.0 (create app at https://developer.atlassian.com/console/myapps/)
JIRA_CLIENT_ID=your-jira-client-id
JIRA_CLIENT_SECRET=your-jira-client-secret
JIRA_REDIRECT_URI=https://apenkin.pro/jira-bot/callback
JIRA_WEBHOOK_SECRET=your-jira-webhook-secret
POLL_INTERVAL=30s
BATCH_WINDOW=1m
CALLBACK_ADDR=:8080

# 32-byte key for AES-256-GCM token encryption (64 hex characters)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-64-char-hex-encryption-key

# SOCKS5 proxy for all outbound connections (optional)
# PROXY_URL=socks5://user:password@host:port

# Admin panel (optional) — your Telegram user ID
# ADMIN_TELEGRAM_ID=123456789

# NATS JetStream (Phase 0 of DDD microservices split). Events are published
# alongside the current monolith when ENABLE_EVENT_PUBLISH=true.
# NATS_URL=nats://localhost:4222
# ENABLE_EVENT_PUBLISH=false

# Phase 1: set EMBED_WEBHOOK_SERVER=false to offload /webhook ingress and
# the 24h webhook refresher to a standalone webhook-svc. Default true
# preserves the current monolith behaviour.
# EMBED_WEBHOOK_SERVER=true
# WEBHOOK_SVC_ADDR=:8081

# Phase 2: identity-svc TokenLease protocol. The monolith exposes the
# endpoint on INTERNAL_ADDR (not on CALLBACK_ADDR). Set
# INTERNAL_AUTH_TOKEN to a shared secret when running more than one
# service. Leave IDENTITY_SVC_URL empty to keep in-process token
# refreshing; set it to direct consumers at a remote identity-svc.
# INTERNAL_ADDR=:9080
# INTERNAL_AUTH_TOKEN=change-me
# IDENTITY_SVC_URL=

# Phase 3: set EMBED_POLLER=false to offload Jira polling to a
# standalone subscription-svc. Default true preserves current behaviour.
# EMBED_POLLER=true
# SUBSCRIPTION_SVC_ADDR=:8082

# Phase 4: set EMBED_SCHEDULER=false to offload cron-triggered reports
# to a standalone scheduler-svc. Default true preserves current
# behaviour.
# EMBED_SCHEDULER=true
# SCHEDULER_SVC_ADDR=:8083
